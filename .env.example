# ─────────────────────────────────────────────────────────────────────────────
# Rooftop Heroes — backend environment variables.
# Copy these into Vercel → Project → Settings → Environment Variables.
# Do NOT commit real values. Leave a channel's vars blank to disable it
# (a lead is still saved to the database and logged regardless).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase) ──────────────────────────────────────────────────────
# Already provisioned for this project. The service_role key is SECRET — get it
# from Supabase → Project Settings → API → "service_role" (NOT the anon key).
SUPABASE_URL=https://mvocjfefkradjpbijbnr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Email alerts (Resend) ────────────────────────────────────────────────────
# Get a key at https://resend.com (free: 100 emails/day). To send to any inbox
# you must verify your sending domain; until then LEAD_FROM must stay on
# onboarding@resend.dev and email only reaches your own Resend account address.
RESEND_API_KEY=
LEAD_EMAIL=owner@example.com
LEAD_FROM=Rooftop Heroes Leads <onboarding@resend.dev>

# ── SMS alerts (Twilio) ──────────────────────────────────────────────────────
# From https://twilio.com. US business texting needs A2P 10DLC registration.
# Numbers must be E.164 format (e.g. +15017728243). Leave blank to skip SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX
LEAD_SMS_TO=+1XXXXXXXXXX

# ── Dashboard login (/admin) ─────────────────────────────────────────────────
# ADMIN_PASSWORD is what the owner types to sign in.
# SESSION_SECRET signs the login cookie — use a long random string. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=
SESSION_SECRET=

# ── Site ─────────────────────────────────────────────────────────────────────
# Your live URL (no trailing slash). Used to add a "View dashboard" link to the
# email/SMS alerts. e.g. https://rooftopheroes.com
SITE_URL=
